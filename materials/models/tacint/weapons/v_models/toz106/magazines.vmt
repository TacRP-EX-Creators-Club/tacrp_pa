VertexLitGeneric
{
 $baseTexture "models/tacint/weapons/v_models/toz106/magazines_D"
 $bumpmap "models/tacint/weapons/v_models/toz106/magazines_N"
 $envmap env_cubemap
 $normalmapalphaenvmapmask 1
 $envmapsaturation "0.250000"
 $envmaptint "[0.006 0.006 0.006]"
 $envmapfresnel 1
 $phong 1
 $phongboost "0.800000"
 $phongfresnelranges "[.5 10 37]"
 $phongexponent 25
 $rimlight 0
 $rimlightexponent 55
 $rimlightboost "0.350000"

 $blendtintbybasealpha 1
    $blendtintcoloroverbase 0.1
    $color2 "[1 1 1]"

    Proxies
    {
        ShellColor
        {
            resultvar $color2
        }
    }
}